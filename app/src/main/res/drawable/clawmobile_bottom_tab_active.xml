<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="90"
                android:startColor="#33140F0A"
                android:endColor="#1A110E0A" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="4dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="19dp" />
            <gradient
                android:angle="90"
                android:startColor="@color/claw_nav_active_fill_top"
                android:endColor="@color/claw_nav_active_fill_bottom" />
            <stroke
                android:width="1dp"
                android:color="@color/claw_nav_active_stroke" />
        </shape>
    </item>

    <item
        android:left="10dp"
        android:top="0dp"
        android:right="10dp"
        android:bottom="55dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="14dp"
                android:topRightRadius="14dp"
                android:bottomLeftRadius="14dp"
                android:bottomRightRadius="14dp" />
            <solid android:color="@color/claw_amber" />
        </shape>
    </item>

</layer-list>
