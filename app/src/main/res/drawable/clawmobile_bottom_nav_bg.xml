<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="90"
                android:startColor="@color/claw_nav_shell"
                android:endColor="#EA0D1110" />
            <stroke
                android:width="1dp"
                android:color="@color/claw_line" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="29dp" />
            <gradient
                android:angle="90"
                android:startColor="#F0161C19"
                android:endColor="@color/claw_nav_inner" />
        </shape>
    </item>

    <item
        android:left="22dp"
        android:top="1dp"
        android:right="22dp"
        android:bottom="77dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="29dp"
                android:topRightRadius="29dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <gradient
                android:angle="90"
                android:startColor="#22F1BE64"
                android:endColor="#00F1BE64" />
        </shape>
    </item>

</layer-list>
