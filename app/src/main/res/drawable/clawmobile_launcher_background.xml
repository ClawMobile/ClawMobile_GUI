<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/claw_ink_950"
                android:centerColor="@color/claw_ink_900"
                android:endColor="#1C120D" />
        </shape>
    </item>

    <item
        android:right="96dp"
        android:bottom="360dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="300dp"
                android:startColor="#3AF1BE64"
                android:endColor="#00F1BE64" />
        </shape>
    </item>

    <item
        android:left="120dp"
        android:top="320dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="340dp"
                android:startColor="#20D6FF9B"
                android:endColor="#00D6FF9B" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="@color/claw_frame" />
        </shape>
    </item>

</layer-list>
