<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="90"
                android:startColor="#FB070A09"
                android:endColor="#EE0D1210" />
            <stroke
                android:width="1dp"
                android:color="@color/claw_line" />
        </shape>
    </item>

    <item android:gravity="top">
        <shape android:shape="rectangle">
            <size android:height="3dp" />
            <corners
                android:topLeftRadius="26dp"
                android:topRightRadius="26dp" />
            <gradient
                android:angle="0"
                android:startColor="@color/claw_ember"
                android:endColor="@color/claw_signal" />
        </shape>
    </item>

</layer-list>
