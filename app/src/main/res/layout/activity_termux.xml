<com.termux.app.terminal.TermuxActivityRootView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_termux_root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Original terminal content -->
        <RelativeLayout
            android:id="@+id/activity_termux_root_relative_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="3dp"
            android:layout_marginVertical="0dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/clawmobile_console_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_marginStart="6dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/clawmobile_console_header_bg"
                android:elevation="10dp"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/clawmobile_console_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/clawmobile_badge_background"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.12"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="@string/clawmobile_console_header_badge"
                        android:textColor="@color/claw_ink_950"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1"
                        android:alpha="0.4"
                        android:background="@color/claw_line" />

                    <TextView
                        android:id="@+id/btn_console_sessions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/clawmobile_terminal_button_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="monospace"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:text="@string/clawmobile_console_action_sessions"
                        android:textColor="@color/claw_text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btn_console_deck"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/clawmobile_terminal_button_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="monospace"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:text="@string/clawmobile_console_action_deck"
                        android:textColor="@color/claw_text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/clawmobile_console_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-condensed"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/clawmobile_console_header_title"
                    android:textColor="@color/claw_text_primary"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/clawmobile_console_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/clawmobile_console_header_subtitle"
                    android:textColor="@color/claw_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/clawmobile_info_tile_bg"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.12"
                            android:text="@string/clawmobile_console_phase_label"
                            android:textColor="@color/claw_text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/clawmobile_console_primary_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif-condensed"
                            android:text="@string/clawmobile_console_phase_idle"
                            android:textColor="@color/claw_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/clawmobile_info_tile_bg"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.12"
                            android:text="@string/clawmobile_console_context_label"
                            android:textColor="@color/claw_text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/clawmobile_console_secondary_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif-condensed"
                            android:text="@string/clawmobile_console_context_idle"
                            android:textColor="@color/claw_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <androidx.drawerlayout.widget.DrawerLayout
                android:id="@+id/drawer_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@+id/clawmobile_console_header"
                android:layout_above="@+id/clawmobile_console_status_bar">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="0dp"
                    android:background="@drawable/clawmobile_terminal_surface_bg"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/clawmobile_info_tile_bg"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.12"
                            android:paddingStart="10dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="6dp"
                            android:text="@string/clawmobile_console_surface_label"
                            android:textColor="@color/claw_text_primary"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/clawmobile_console_surface_status"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:fontFamily="monospace"
                            android:singleLine="true"
                            android:text="@string/clawmobile_console_surface_status"
                            android:textColor="@color/claw_text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="10dp"
                        android:layout_weight="1">
                        <com.termux.view.TerminalView
                            android:id="@+id/terminal_view"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:defaultFocusHighlightEnabled="false"
                            android:focusableInTouchMode="true"
                            android:scrollbarThumbVertical="@drawable/terminal_scroll_shape"
                            android:scrollbars="vertical"
                            tools:ignore="UnusedAttribute" />
                    </FrameLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/left_drawer"
                    android:layout_width="272dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:choiceMode="singleChoice"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="0dp"
                    android:descendantFocusability="blocksDescendants"
                    android:orientation="vertical"
                    android:background="?attr/termuxActivityDrawerBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingTop="18dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="14dp">
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:letterSpacing="0.12"
                                    android:text="@string/clawmobile_drawer_title"
                                    android:textColor="@color/claw_text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="monospace"
                                    android:text="@string/clawmobile_drawer_subtitle"
                                    android:textColor="@color/claw_text_muted"
                                    android:textSize="11sp" />
                            </LinearLayout>
                            <ImageButton
                                android:id="@+id/settings_button"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:layout_marginStart="12dp"
                                android:src="@drawable/ic_settings"
                                android:background="@drawable/clawmobile_terminal_button_bg"
                                android:padding="10dp"
                                android:contentDescription="@string/clawmobile_open_control_deck"
                                app:tint="?attr/termuxActivityDrawerImageTint" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="14dp"
                            android:layout_marginEnd="14dp"
                            android:alpha="0.3"
                            android:background="@color/claw_line" />

                        <ListView
                            android:id="@+id/terminal_sessions_list"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_gravity="top"
                            android:layout_weight="1"
                            android:choiceMode="singleChoice"
                            android:clipToPadding="false"
                            android:divider="@android:color/transparent"
                            android:dividerHeight="10dp"
                            android:paddingStart="14dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="14dp"
                            android:longClickable="true" />

                        <LinearLayout
                            style="?android:attr/buttonBarStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingTop="0dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="18dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/toggle_keyboard_button"
                                style="@style/TermuxActivity.Drawer.ActionButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:text="@string/action_toggle_soft_keyboard" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/new_session_button"
                                style="@style/TermuxActivity.Drawer.ActionButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:text="@string/action_new_session" />
                    </LinearLayout>
                </LinearLayout>

            </androidx.drawerlayout.widget.DrawerLayout>

            <LinearLayout
                android:id="@+id/clawmobile_console_status_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="10dp"
                android:layout_above="@+id/terminal_toolbar_view_pager"
                android:background="@drawable/clawmobile_progress_panel_bg"
                android:elevation="6dp"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp">

                <TextView
                    android:id="@+id/clawmobile_console_footer_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"
                    android:text="@string/clawmobile_console_footer_status"
                    android:textColor="@color/claw_signal"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/clawmobile_console_footer_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="1dp"
                    android:text="@string/clawmobile_console_footer_detail"
                    android:textColor="@color/claw_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

                <androidx.viewpager.widget.ViewPager
                    android:id="@+id/terminal_toolbar_view_pager"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/clawmobile_terminal_toolbar_bg"
                    android:layout_alignParentBottom="true" />

        </RelativeLayout>

        <!-- Launcher overlay (on top of terminal) -->
        <include layout="@layout/view_launcher_overlay" />

    </FrameLayout>

    <View
        android:id="@+id/activity_termux_bottom_space_view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/transparent" />

</com.termux.app.terminal.TermuxActivityRootView>
